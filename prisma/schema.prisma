datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(uuid())
  fullName      String
  username      String          @unique
  email         String          @unique
  password      String
  role          String          @default("Usuario") // "Administrador" | "Usuario"
  status        String          @default("Activo")  // "Activo" | "Inactivo" | "Suspendido"
  createdAt     DateTime        @default(now())
  lastLogin     DateTime?
  phone         String?         // optional phone number
  city          String?         // optional city
  avatarUrl     String?         // optional avatar image url
  tickets       SupportTicket[]
  reservations  Reservation[]
}

model Destination {
  id                  String        @id @default(uuid())
  title               String
  location            String
  price               Float
  category            String        // "Historia" | "Biología" | "Ciencia" | "Arte" | "Geografía" | "Literatura"
  description         String
  imageUrl            String
  pedagogicalGuideUrl String
  benefits            String[]      // Native PostgreSQL string array
  latitude            Float
  longitude           Float
  rating              Float         @default(5.0)
  createdAt           DateTime      @default(now())
  reservations        Reservation[]
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  message   String
  status    String   @default("Pendiente") // "Pendiente" | "En progreso" | "Resuelto"
  createdAt DateTime @default(now())
}

model Reservation {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  numTeachers   Int         @default(0)
  numStudents   Int         @default(0)
  createdAt     DateTime    @default(now())
}
